# =============================================================================
# MindReset.ai — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# Postgres connection string (Vercel Postgres, Supabase, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mindreset"

# Clerk authentication — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<your-clerk-publishable-key>"
CLERK_SECRET_KEY="<your-clerk-secret-key>"
# Clerk URLs — point at our custom branded routes (not Clerk-hosted defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/account"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/account"

# Clerk webhook signing secret — from Clerk dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET="whsec_<your-clerk-webhook-secret>"

# Anthropic Claude API — powers MiniMind chat and the assessment engine
ANTHROPIC_API_KEY="<your-anthropic-api-key>"

# Stripe — server-side secret for charges and the webhook signing secret
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<your-stripe-webhook-secret>"
# Public Stripe key used by Stripe.js in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="<your-stripe-publishable-key>"

# Stripe Price IDs — create these in the Stripe dashboard (test mode first,
# then live mode). Copy the price_xxx ID for each product and paste here.
# Test-mode and live-mode IDs are different; swap them when switching modes.
STRIPE_PRICE_ESSENTIAL_MONTHLY="price_<essential_monthly>"
STRIPE_PRICE_ESSENTIAL_ANNUAL="price_<essential_annual>"
STRIPE_PRICE_EXTENDED_MONTHLY="price_<extended_monthly>"
STRIPE_PRICE_EXTENDED_ANNUAL="price_<extended_annual>"
STRIPE_PRICE_TOP_UP="price_<top_up>"

# Resend — transactional email (welcome email, future sequences)
RESEND_API_KEY="<your-resend-api-key>"
# From address — must be a verified domain in Resend dashboard
# Default: MindReset.ai <hello@mindreset.ai>
RESEND_FROM_EMAIL="MindReset.ai <hello@mindreset.ai>"

# Cron job auth — Vercel sends this as Bearer token; generate with: openssl rand -hex 32
CRON_SECRET="<your-cron-secret>"

# Admin panel email allowlist (comma-separated). Users signed into Clerk
# with any of these emails see /admin; everyone else gets a 404.
ADMIN_EMAILS="yulialoya@gmail.com"

# Message encryption key — AES-256-GCM, 32 bytes as 64-char hex.
# Generate with: openssl rand -hex 32
# CRITICAL: never rotate this without first re-encrypting all existing messages.
# Never lose this key — encrypted messages cannot be recovered without it.
MESSAGE_ENCRYPTION_KEY="<64-char-hex-string>"

# Supabase direct connection (needed for Prisma schema push / generate outside Vercel)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/mindreset"

# Upstash Redis — rate limiting (provisioned via Vercel Marketplace / Vercel KV integration)
# Vercel creates these with KV_ prefix. Check Settings → Environment Variables for exact names.
KV_REST_API_URL="https://<your-database>.upstash.io"
KV_REST_API_TOKEN="<your-upstash-rest-token>"

# Groq API — voice transcription for /api/minimind/transcribe.
# Sign up at https://console.groq.com/ and generate an API key.
# In the Groq console, review Data Controls settings — Zero Data Retention
# is the goal (matches locked decision #22) but may require a paid plan
# to enable. Confirm the retention policy that applies to your plan.
GROQ_API_KEY="<your-groq-api-key>"

# Public base URL — used for OAuth redirects, webhook callbacks, email links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
