// =============================================================================
// MindReset.ai — Database Schema
// Postgres via Prisma. Read architecture.md for the plain-language overview.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// USER
// =============================================================================
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Preferences (the lang+theme system from screening/landing)
  locale            String    @default("en")    // en | ru | uk | pl | de | es | fr
  themePref         String    @default("system") // day | night | system

  // Consent & screening (legal gate before any product use)
  tcAcceptedAt      DateTime?
  privacyAcceptedAt DateTime?
  disclaimerAcknowledgedAt DateTime?
  screeningResult   String?                      // green | yellow | red | null
  screeningResultAt DateTime?
  welcomeEmailSentAt DateTime?                   // null = not yet sent; set on first send

  // Stripe billing identifiers
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique

  // Tier + message allowance (Block B)
  currentTier             String?             // 'free' | 'essential' | 'extended' | null
  messagesUsedThisCycle   Int       @default(0)
  cycleResetAt            DateTime?
  topUpMessagesRemaining  Int       @default(0)
  lifetimeMessagesUsed    Int       @default(0)

  // Legacy access gate (populated by webhook — kept for backwards compat)
  miniMindActive    Boolean   @default(false)
  miniMindUntil     DateTime?

  // Marketing-email consent (UK PECR + GDPR).
  // - marketingConsent: explicit opt-in. Default FALSE — explicit consent
  //   is the only valid basis under PECR for unsolicited marketing email.
  //   Set TRUE when the user ticks the consent box at sign-up (PR 3b) or
  //   any other future opt-in surface.
  // - marketingUnsubAt: timestamp of the last unsubscribe. Set when the
  //   user clicks the one-click unsubscribe link in any marketing email.
  //   marketingConsent is also flipped FALSE in the same write. We keep
  //   the timestamp separately so we can audit "this user unsubscribed
  //   from marketing on date X" without losing the signal if they later
  //   re-opt-in.
  marketingConsent          Boolean   @default(false)
  marketingUnsubAt          DateTime?
  // Stamp set the first time the user is shown the marketing-consent
  // banner on /home (PR #89). Banner only appears when this is null —
  // dismissing or accepting both set it, so the prompt is shown at most
  // once. After that the user can still opt in / out via the toggle in
  // the /home Settings section.
  marketingConsentPromptedAt DateTime?
  // Onboarding drip stamps (PR #96).
  // - drip1SentAt: Day-1 nudge sent (Email 2, "Something brought you
  //   here"). Sent when user signed up 24-48h ago AND hasn't sent a
  //   MiniMind message yet AND marketingConsent=true.
  // - drip2SentAt: Day-7 re-engagement sent (Email 3, "A gentle
  //   reminder"). Sent when user signed up 7-14d ago AND lifetime
  //   messages < 5 AND marketingConsent=true.
  // Both are claimed via updateMany so the cron job is idempotent —
  // re-running the cron after a partial failure won't double-send.
  drip1SentAt               DateTime?
  drip2SentAt               DateTime?

  // GDPR account-deletion flow (Article 17 "right to erasure").
  // - deletedAt: set when the user confirms deletion via email link. Soft-
  //   delete marker — once set the user is signed out and treated as gone
  //   on every surface, but the row stays for the grace window.
  // - deletionScheduledAt: when the daily cron will hard-delete. Computed
  //   as max(now + 30 days, current subscription period end) so paid users
  //   aren't billed for time they can't access.
  deletedAt              DateTime?
  deletionScheduledAt    DateTime?

  // Relations
  screeningResponses     ScreeningResponse[]
  wellbeingSnapshot      WellbeingSnapshot?
  conversations          Conversation[]
  safetyEvents           SafetyEvent[]
  purchases              Purchase[]
  moduleProgress         ModuleProgress[]
  recodeProgress         RecodeProgress?
  practices              Practice[]
  deletionTokens         AccountDeletionToken[]
  testimonials           Testimonial[]
  // The Journey
  journeyTurns           JourneyTurn[]
  journeyPracticeRuns    JourneyPracticeRun[]
  journeyParts           JourneyPart[]
  journeyForeignFiles    JourneyForeignFile[]
  journeySignatureImages JourneySignatureImage[]
  journeyPatterns        JourneyPattern[]
  journeyMessages        JourneyMessage[]
  // States & Themes — state module sessions.
  stateSessions          StateSession[]
  stateModuleMemories    StateModuleMemory[]
  themeSessions          ThemeSession[]
  // AI usage rows (per Anthropic call — token counts + cost). Nullable
  // relation because internal admin / support-categorise calls may not
  // be attributable to a single user.
  aiUsages               AiUsage[]
  // Platform Step 1 (2026-07-20) — recommendation log (append-only).
  platformRecommendations PlatformRecommendation[]

  // Pilot programme (PR ρ, 2026-07-12). Set on redemption of a
  // PilotInvitation code. pilotTrialEndsAt is the hard expiry — the
  // Journey access gate treats now > pilotTrialEndsAt as expired even
  // if a completed recode Purchase exists. After expiry the user is
  // shown a "Continue with 50% off" CTA; the discount is applied via a
  // Stripe promotion code (env: STRIPE_PROMO_CODE_PILOT_50).
  pilotTrialStartedAt  DateTime?
  pilotTrialEndsAt     DateTime?
  pilotInvitation      PilotInvitation? @relation(fields: [pilotInvitationId], references: [id], onDelete: SetNull)
  pilotInvitationId    String?  @unique
}

// =============================================================================
// PILOT INVITATIONS
// =============================================================================
// Self-serve invitation codes for the 4-week clinical pilot. Julia creates
// codes in /admin/pilot, sends the redeem link to the tester by email
// (outside the app), and the tester claims by visiting /redeem/[code].
// One code → one user. Redemption is idempotent — a signed-in visit to
// /redeem/[code] returns the "already redeemed by you" screen instead of
// erroring.
//
// On redeem:
//   - PilotInvitation.redeemedAt, redeemedByUserId, pilotInvitationId are stamped
//   - User.pilotTrialStartedAt = now
//   - User.pilotTrialEndsAt = now + trialDays
//   - Purchase(productType='recode', status='completed', amount=0) is created
//     so the existing Journey access gate finds a grant, but with the extra
//     trial-window check on top.
model PilotInvitation {
  id                 String    @id @default(cuid())
  code               String    @unique
  createdAt          DateTime  @default(now())
  createdByEmail     String?   // Julia's email at creation time (audit trail)
  notes              String?   @db.Text // free-text: "Sofia, RU, referred by Petya"

  trialDays          Int       @default(30)
  expiresAt          DateTime? // invitation expiry (rejects redemption after)

  redeemedAt         DateTime?
  redeemedByUserId   String?   @unique
  redeemedByUser     User?

  // In-app questionnaire lifecycle (PR ω3a, 2026-07-14). Julia's method:
  // pilot testers fill a Before form at the start of their arc and an
  // After form ~30 days later; the 6 identical Likert scales in each
  // form are the pilot's core measurement.
  //
  // `beforeFormFilled` / `afterFormFilled` auto-flip when the tester
  // submits via /api/pilot/questionnaire (the API stamps them + the
  // matching *FilledAt* timestamp atomically in the same transaction).
  // The admin surface at /admin/pilot ALSO exposes manual toggles as a
  // fallback (e.g. to record a submission that happened outside the
  // app, or to reset a row for a re-take) — the API and the admin
  // toggles are both safe: neither can corrupt the response data.
  //
  // The *FilledAt* timestamps are what the 30-day cron will read to
  // know when to send the After email; *EmailSentAt* gates the trigger
  // sends so the same tester never gets nudged twice.
  // `followUp3mSent` and `quoteApproved` remain admin-only toggles.
  beforeFormFilled       Boolean   @default(false)
  beforeFormFilledAt     DateTime?
  beforeFormEmailSentAt  DateTime?
  afterFormFilled        Boolean   @default(false)
  afterFormFilledAt      DateTime?
  afterFormEmailSentAt   DateTime?
  followUp3mSent         Boolean   @default(false)
  quoteApproved          Boolean   @default(false)

  // Revoke — kills a tester's active pilot without deleting the row.
  // checkJourneyAccess treats revokedAt-not-null as expired.
  revokedAt          DateTime?
  revokedReason      String?

  testerResponses    TesterResponse[]

  @@index([redeemedByUserId])
}

// =============================================================================
// TESTER RESPONSE — the two pilot questionnaires
// =============================================================================
// PR ω3a (2026-07-14). One row per (invitation, formType). The 6
// identical Likert scales are typed columns so cross-form SQL comparison
// ("understand ↑ / stuck ↓") is trivial; everything else — consents,
// About You radio picks, Your Pattern multi-checks, free-text — lives
// in the `answers` JSON blob so questions can evolve without a
// migration per iteration.
model TesterResponse {
  id             String           @id @default(cuid())
  invitation     PilotInvitation  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitationId   String
  formType       String           // 'before' | 'after' | 'followup_3m'
  submittedAt    DateTime         @default(now())

  // The 6 KEY Likert 0–10 scales. Same 6 in Before and After —
  // Julia's md: "these exact questions repeat at the end — this is
  // the measurement."
  scaleUnderstand   Int?
  scaleNotice       Int?
  scaleChoose       Int?
  scaleHardOnSelf   Int?
  scaleAffectsLife  Int?
  scaleStuck        Int?

  // Free-text + multi-choice answers. Shape per formType — validated by
  // Zod at the API layer (lib/pilot/questionnaire-schema.ts).
  answers        Json

  @@unique([invitationId, formType])
  @@index([invitationId])
}

// =============================================================================
// TESTIMONIALS — user stories for Landing + Pricing social proof
// =============================================================================
// Submitted via /share-your-story (signed-in or anonymous), moderated by
// Julia (soft-launch: directly via Supabase SQL editor; later: admin UI).
// Public surfaces only render approved testimonials, and only when there
// are ≥ 3 to avoid the "lonely zero/one" effect.
model Testimonial {
  id              String    @id @default(cuid())
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?   // null when submitted anonymously (no auth)

  publicName      String    // what we display ("Jane", "Anonymous", etc.) — user's choice
  ageRange        String?   // optional. "18-24" | "25-34" | "35-44" | "45-54" | "55-64" | "65+"
  story           String    @db.Text  // max 1500 chars enforced at the API
  locale          String    // en | ru | … — testimonial shows on matching-locale Landing/Pricing
  consent         Boolean   // must be true at submit; UI prevents otherwise

  status          String    @default("pending")  // pending | approved | rejected
  moderationNotes String?   @db.Text             // Julia's notes (private)

  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?

  @@index([status, locale, approvedAt])
  @@index([userId])
}

// =============================================================================
// ACCOUNT DELETION TOKENS — single-use email-confirmation tokens
// =============================================================================
model AccountDeletionToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  tokenHash  String   @unique  // sha256 of the raw token; raw lives only in the email
  createdAt  DateTime @default(now())
  expiresAt  DateTime          // 1 hour from creation
  consumedAt DateTime?         // set when redeemed (token becomes invalid)

  @@index([userId])
  @@index([expiresAt])
}

// =============================================================================
// SCREENING — the Section 0 gate (mirrors screening.jsx)
// =============================================================================
model ScreeningResponse {
  id                 String   @id @default(cuid())
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String?
  createdAt          DateTime @default(now())

  // Raw answers (stored as JSON so we can re-classify if rules change)
  exclusionFlags      Json    // { "0": true, "4": true, ... }
  functionalityScores Json    // { "0": 4, "1": 5, ... }  values 0-5
  emotionalScores     Json    // { "0": 2, "1": 1, ... }
  traumaLevel         Int     // 0..3 (the single-select trauma question)
  cognitiveAnswers    Json    // { "0": "yes", "1": "no", ... }
  consentItems        Json    // { "0": true, "1": true, ... }

  // Classification
  result        String        // green | yellow | red
  reasonSummary String?       // audit trail — why this result
  classifierVer String?       // version of the rules that produced it

  @@index([userId])
}

// =============================================================================
// DIAGNOSTIC PROFILE — the hidden sensor (one row per user)
// Updated asynchronously after meaningful conversations.
// User never sees this directly. Drives routing, recommendations, gating.
// =============================================================================
model WellbeingSnapshot {
  id                         String   @id @default(cuid())
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                     String   @unique
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  // Attachment style — best guess with weights summing ~1
  // e.g. { "anxious": 0.6, "avoidant": 0.2, "secure": 0.1, "disorganized": 0.1 }
  attachmentStyle            Json?

  // Current state (the 4 States in the methodology)
  predominantState           String?  // see DetectedState in lib/minimind/safety/verifier.ts (9 surface states for MiniMind layer; distinct from the 4 deep States used in the Journey programme)
  stateIntensity             Int?     // 1..5
  stateFirstObservedAt       DateTime?

  // Active themes (the 5 Themes), weighted
  // e.g. [{ "name": "money", "weight": 0.7 }, { "name": "shame", "weight": 0.3 }]
  activeThemes               Json?

  // Repeat-state counter — the rule: 3 occurrences in 7 days → recommend deeper module
  recentStateOccurrences     Json?    // [{ "state": "anxiety_overwhelm", "detectedAt": "2026-05-15T..." }, ...]

  // Channel preference — affects which practices the AI offers
  channelPreference          String?  // visual | somatic | emotional | cognitive

  // Regulation capacity (self-soothing ability) — gates depth progression
  regulationCapacity         Int?     // 0..10

  // Risk markers — aggregated patterns (distinct from acute SafetyEvent log)
  // e.g. { "isolation": 0.4, "dysregulation": 0.6, "rumination": 0.3 }
  riskMarkers                Json?

  // Free-form notes from the assessment engine
  engineNotes                String?  @db.Text

  // Provenance
  lastAnalyzedConversationId String?
  lastAnalyzedAt             DateTime?
  modelVersion               String?  // which assessment-engine version produced this

  // Platform Step 1 (2026-07-20) — the 4-step account-page onboarding.
  // Button CODES, not free text (display copy lives in the i18n bundles;
  // all locales gender-neutral per locked decision). User-authored and
  // user-visible; products read but never write these. See
  // docs/platform/plan-2026-07-20-step1-platform-profile.md for the
  // code vocabularies and the consumption map.
  onboardingWhy              String?
  onboardingArea             String?
  onboardingStyle            String?
  onboardingGoal             String?
  onboardingCompletedAt      DateTime?
  onboardingSkippedAt        DateTime?
}

// =============================================================================
// PLATFORM RECOMMENDATION — append-only log (Platform Step 1, 2026-07-20)
// =============================================================================
// One row per recommendation shown (or to be shown) to a user. Writers
// arrive in build step 4 (platform rules + MiniMind catalog) and step 7
// (Journey step-down); Step 1 ships the table and the primitives only.
// "Never pushed" is enforced on this data: responses are recorded,
// declines set a cool-off, and rules must consult the log before
// re-recommending.
model PlatformRecommendation {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  createdAt       DateTime  @default(now())

  // What is recommended: 'minimind' | 'journey' | 'state:<id>' | 'theme:<id>'
  product         String
  // Who recommended: 'platform_rule' | 'minimind' | 'journey'
  source          String
  // Plaintext rule identifier (e.g. 'repeat_state_3in7'); null for AI-sourced
  ruleKey         String?
  // Plain-language reason shown to the user. May quote the user's own
  // words, so encrypted at rest like all user-words fields.
  reasonEncrypted String?

  shownAt         DateTime?
  response        String?   // 'accepted' | 'declined' | 'ignored'
  respondedAt     DateTime?
  coolOffUntil    DateTime?

  @@index([userId, createdAt])
}

// =============================================================================
// CONVERSATIONS — every session, whatever kind
// =============================================================================
model Conversation {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  // What kind of session
  kind        String    // minimind | module | recode_block
  moduleId    String?   // if kind = module (e.g. "anxiety", "money")
  recodeBlock Int?      // 1..8 if kind = recode_block
  depthLevel  String?   // surface | middle | deep (for modules/recode)

  // Check-ins — required before deep work, optional for casual MiniMind
  preMood     Int?      // 0..10
  preEnergy   Int?      // 0..10
  preSafety   Int?      // 0..10
  postMood    Int?
  postEnergy  Int?
  postSafety  Int?

  // Outcomes
  redFlagged  Boolean   @default(false)  // any safety event in this session?
  sscPassed   Boolean?                   // Stabilisation+Satisfaction Criteria met?

  // Set true by Phase 3c safety scanner when a Sev 5 trigger fires. Blocks
  // normal MiniMind flow; only the cooldown holding message is delivered
  // until the LLM verifier detects explicit safety confirmation in a user
  // reply, at which point the column flips back to false.
  inCrisisCooldown Boolean @default(false)

  // Sliding-window retention: updated on every new message via the chat route.
  // The daily cron deletes Conversation rows where lastActivityAt < 12 months ago.
  // Messages cascade (onDelete: Cascade on Message.conversationId).
  lastActivityAt DateTime @default(now())

  messages     Message[]
  safetyEvents SafetyEvent[]

  @@index([userId, startedAt])
  @@index([lastActivityAt])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  role      String   // user | assistant | system
  content   String   @db.Text  // AES-256-GCM encrypted via lib/encrypt.ts (prefix enc:v1:); legacy rows are plaintext until backfill runs
  timestamp DateTime @default(now())

  // Signals extracted by the assessment engine in real time
  // e.g. { "emotions": ["sadness","shame"], "somatic_cues": ["tightness chest"], "red_flag_keywords": [] }
  detectedSignals Json?

  // True when the assistant reply was saved after a streaming error — i.e. only
  // a partial response reached the user. Set by /api/minimind/chat on stream failure.
  partial Boolean @default(false)

  @@index([conversationId, timestamp])
}

// =============================================================================
// SAFETY — immutable red-flag log
// =============================================================================
model SafetyEvent {
  id             String        @id @default(cuid())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?
  messageId      String?       // the message that triggered detection
  triggeredAt    DateTime      @default(now())

  type           String        // suicidal_ideation | self_harm | abuse_disclosure | psychosis_signal | substance_crisis | other
  severity       Int           // 1..5
  triggerExcerpt String?       // anonymised snippet for review

  aiResponse     String        @db.Text  // what the system said + which resources offered

  // Human review queue
  humanReviewed  Boolean       @default(false)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?

  // Outcome
  userAcknowledged Boolean     @default(false)  // did user acknowledge crisis resources?
  followedUpAt   DateTime?

  @@index([userId, triggeredAt])
  @@index([humanReviewed, triggeredAt])  // moderation queue lookup
}

// =============================================================================
// PRODUCTS & PURCHASES
// =============================================================================
model Purchase {
  id              String    @id @default(cuid())
  // Cascade on user delete: prior default (Restrict) blocked
  // prisma.user.delete for any paying user, taking down the Clerk
  // user.deleted webhook and the GDPR retention cron. Restored to
  // Cascade to match the rest of the Journey model graph and let
  // right-to-erasure actually work.
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String

  productType     String    // minimind_sub | module | recode | state_module
  productId       String?   // module id ("anxiety", "apathy", "loss_of_self", "inner_emptiness", ...) or null for recode/sub
  amount          Int       // pence (or cents — currency below)
  currency        String    @default("GBP")

  stripeSessionId String?   @unique
  stripeChargeId  String?   @unique
  status          String    // pending | completed | refunded | failed

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  // Time-bounded access — set on state_module purchases at
  // Stripe webhook time (completedAt + 30 days). Access gate treats
  // now > accessExpiresAt as expired. Null on non-time-bounded
  // products (Journey, MiniMind sub, top-up).
  accessExpiresAt DateTime?

  // The Journey (productType = 'recode') — access window and abuse cap.
  //
  // firstAccessedAt: stamped on the first successful /api/journey/turn
  // for this Purchase. From that moment, access lasts 365 days.
  // Journey-only fields; null on module / minimind_sub / one-off top-up rows.
  //
  // journeyMessagesUsed: incremented per accepted turn. Enforces a hard
  // anti-abuse ceiling (Julia decided 2026-07-03: no product-level msg cap,
  // but a stolen-session / bot floor at 5,000 msgs/year — 12× a heavy
  // engager's realistic use of the 8-stage arc).
  firstAccessedAt      DateTime?
  journeyMessagesUsed  Int       @default(0)

  @@index([userId])
  // Fast lookup for the Journey access gate — most queries filter by
  // (userId, productType, status) already; this composite index means the
  // 1-year-expiry gate can be answered without scanning the user's other
  // purchase rows.
  @@index([userId, productType, status])
}

// =============================================================================
// Stripe webhook idempotency log.
//
// Stripe re-delivers webhook events when our endpoint times out or returns a
// non-2xx response — and can do so days later. The first thing the webhook
// handler does is try to insert the event ID here; the @id (primary key) is
// the Stripe event ID, so a duplicate insert throws P2002 and we short-circuit
// the handler. Without this, retries of `invoice.payment_succeeded` would
// re-zero `messagesUsedThisCycle` mid-cycle, and retries of subscription
// upserts could re-run the first-cycle counter reset.
//
// Per CLAUDE.md, this migration is applied manually in Supabase by the owner.
// =============================================================================
model StripeEvent {
  id          String   @id  // Stripe event ID, e.g. "evt_1ABC..."
  type        String   // "invoice.payment_succeeded", etc.
  processedAt DateTime @default(now())
}

// =============================================================================
// Inbound support emails + outbound replies.
//
// Pattern A (locked 2026-05-28): every inbound message lands here. AI reads
// it and writes a draft reply into `draftReply`; admin reviews and approves
// or edits via the /admin/support queue. Phase 2 will auto-send for a tight
// whitelist of routine categories. Phase 3 tightens + expands. Schema covers
// the full pipeline; PR 2a writes only the structural fields, PR 2b populates
// the AI fields, PR 2c wires Resend Inbound to the create path.
//
// Migration applied manually in Supabase per CLAUDE.md.
// =============================================================================
model SupportEmail {
  id              String    @id @default(cuid())
  fromEmail       String
  fromName        String?
  subject         String
  bodyText        String
  bodyHtml        String?
  // Resend Inbound message ID — unique gate so a retried webhook delivery
  // does not create a duplicate ticket. Null when an email was created via
  // the /admin "add test email" path (PR 2a).
  resendInboundId String?   @unique
  receivedAt      DateTime

  // AI categoriser output — populated in PR 2b by lib/support/categorise.ts.
  locale          String?   // detected language: en|ru|fr|de|es|it|pl|pt
  category        String?   // billing | emotional | methodology | crisis | other
  urgency         String    @default("normal")  // normal | elevated | crisis
  draftReply      String?   // AI-generated draft, editable by admin
  draftLocale     String?

  // Workflow state. pending = needs admin attention; drafted = AI has drafted
  // a reply, awaiting review; auto_queued = AI draft is on a short hold and
  // will auto-send when autoSendAt passes (Phase 2 — narrow whitelist);
  // replied = a reply has been sent (manual or auto); escalated = needs
  // manual handling outside this flow (e.g. crisis routed to phone resource).
  status          String    @default("pending")

  // When status=auto_queued, the cron at /api/cron/support-autosend picks
  // up rows where autoSendAt <= now() and dispatches the draftReply via
  // Resend. Null for all manual-review rows.
  autoSendAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  replies         SupportEmailReply[]

  @@index([status, receivedAt])
  @@index([status, autoSendAt])
}

// =============================================================================
// Marketing campaign audit log.
//
// One row per send fired from /admin/marketing. Records what went out, who
// it went to, and how many recipients succeeded vs failed at the Resend
// API layer. Body is stored in plaintext for compliance review — the same
// way the live unsubscribe link in each email is the per-recipient one
// (computed at send time, not stored here).
//
// Per-recipient delivery state lives in Resend's own dashboard (their
// EmailEvents / Logs) — we don't mirror it. recipientCount + successCount
// + failureCount is enough for a launch glance; if a customer says "I
// didn't get your email", we look it up by their email in Resend Logs.
// =============================================================================
// =============================================================================
// Newsletter subscribers — Landing page email capture.
//
// Distinct from User: these are people who entered an email on the Landing
// page to opt in to occasional updates BEFORE signing up for an account.
// Some will later become Users; the relationship isn't tracked here
// because dedup is by email at send time (the marketing send loop
// already filters Users with marketingConsent=true, so a Newsletter
// row whose email later signs up just gets two copies of the marketing
// list — the send-side dedup is the right place to handle that, not
// here).
//
// Unsubscribe uses the same HMAC token pattern as User unsubscribe but
// signs the NewsletterSubscriber.id (not a userId). The /unsubscribe
// page will branch on token type once newsletter sends ship in PR 3c.
//
// Migration applied manually in Supabase per CLAUDE.md.
// =============================================================================
model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  locale          String    @default("en")
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  @@index([subscribedAt])
}

model MarketingSend {
  id             String   @id @default(cuid())
  subject        String
  body           String   @db.Text
  audience       String   // 'all_consented' for now; PR 3c may add segments
  sentByAdminId  String?
  recipientCount Int
  successCount   Int
  failureCount   Int
  sentAt         DateTime @default(now())

  @@index([sentAt])
}

model SupportEmailReply {
  id              String   @id @default(cuid())
  supportEmail    SupportEmail @relation(fields: [supportEmailId], references: [id], onDelete: Cascade)
  supportEmailId  String

  toEmail         String
  subject         String
  body            String

  // Clerk user ID of the admin who sent. Null when autoSent=true (Phase 2
  // whitelist auto-send shipping in a later PR).
  sentByAdminId   String?
  resendId        String?  // Resend send ID for delivery tracing
  autoSent        Boolean  @default(false)

  sentAt          DateTime @default(now())

  @@index([supportEmailId])
}


// =============================================================================
// PROGRESS TRACKING
// =============================================================================
model ModuleProgress {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  moduleId       String    // e.g. "anxiety", "money", "shame"
  moduleKind     String    // state | theme

  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  completedAt    DateTime?

  currentStep    Int       @default(0)
  totalSteps     Int
  depth          String    // surface | middle | deep

  sscPassed      Boolean   @default(false)  // gates progression to next step

  @@unique([userId, moduleId])
  @@index([userId])
}

model RecodeProgress {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @unique

  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())

  // Legacy field — kept for backward compatibility, no longer authoritative.
  // `currentStage` below is the source of truth.
  currentBlock   Int       @default(1)
  blockProgress  Json      @default("{}")

  isPaused       Boolean   @default(false)
  pausedAt       DateTime?
  pauseReason    String?

  // ---------------------------------------------------------------------------
  // The Journey runtime — added Slice 1 of docs/implementation/journey-build-plan.md
  // All *Encrypted fields use lib/encrypt.ts (AES-256-GCM). User-words content
  // is encrypted at rest per UK GDPR Article 9 (special-category data).
  // ---------------------------------------------------------------------------

  // The persistent inner landscape (1:1 fields)
  anchorTextEncrypted          String?
  anchorSetAt                  DateTime?
  identityAnchorEncrypted      String?
  identityAnchorSetAt          DateTime?
  adultSelfQualitiesEncrypted  String?
  processingChannel            String?   // visual | kinesthetic | emotional | cognitive | verbal | mixed

  // Stage + depth state
  currentStage                 Int       @default(1)   // 1..8 internal stage
  currentDepth                 String    @default("surface") // surface | middle | deep
  lastIntensity                Int?      // 0..10
  lastIntensityAt              DateTime?
  lastDeepLayerContactAt       DateTime? // for the soft 48-hour settling-time signal

  // MII (7 criteria), JSON for queryability and clinical review.
  // Shape documented in docs/implementation/journey-build-plan.md §3.1
  mii                          Json      @default("{}")

  // Stage 8 tracking
  stage8WeeksElapsed           Int       @default(0)

  // Frozen-for-review (Red Flag protocol per Shared Core §7)
  frozenForReview              Boolean   @default(false)
  frozenAt                     DateTime?
  frozenReason                 String?

  // Discharge
  dischargedAt                 DateTime?

  // Rolling 2–4 sentence continuity note the AI writes for itself at session
  // close. Loaded fresh on every turn — gives cross-session continuity without
  // replaying every prior message.
  continuityNoteEncrypted      String?

  // Journey P3 (2026-07-19, audit RC2) — session task contract.
  // Encrypted JSON: { presentingRequest, expectedHelp, currentFocus,
  // completionCriterion } in the user's own words. Merged field-wise
  // (non-empty values only) so a sparse or generic model emission never
  // erases a valid contract.
  taskContractEncrypted        String?
}

// =============================================================================
// JOURNEY AUDIT LOG — append-only, one row per AI turn
// =============================================================================
model JourneyTurn {
  id                       String         @id @default(cuid())
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String
  createdAt                DateTime       @default(now())

  // Operational metadata — plain (no user content), queryable for analytics + gate logic
  stageAtTurn              Int
  depthAtTurn              String
  intensityReported        Int?
  safetyFlag               String         @default("none") // none | watch | red_flag
  redFlagType              String?
  recommendedAction        String?

  // The full state report (may contain user-words content) is encrypted
  stateReportEncrypted     String?

  // Hash of the user's message — for audit cross-reference without storing content
  userMessageHash          String?

  practiceRuns             JourneyPracticeRun[]

  @@index([userId, createdAt])
}

// =============================================================================
// JOURNEY PRACTICE RUNS — canonical (named, anatomy-defined) + generated practices
// =============================================================================
model JourneyPracticeRun {
  id                       String         @id @default(cuid())
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String
  turn                     JourneyTurn    @relation(fields: [turnId], references: [id], onDelete: Cascade)
  turnId                   String
  createdAt                DateTime       @default(now())

  stageAtRun               Int
  kind                     String         // canonical | generated
  name                     String         // "Personal Anchor Identification" | "Inner Child Visit at age 10" | ...
  family                   String?        // regulation | somatic | landscape | narrative | compassion
  triggeredBy              String?        // brief abstract note (no user-words content)
  userImagesEncrypted      String?        // user's images for this practice (encrypted)
  depth                    String?        // surface | middle | deep
  status                   String         // started | mid | completed | aborted_user_request | aborted_overwhelm
  modalitySwitchedFrom     String?
  modalitySwitchedTo       String?

  @@index([userId])
}

// =============================================================================
// JOURNEY INNER PARTS — parts the user has met, in their own words
// =============================================================================
model JourneyPart {
  id                              String         @id @default(cuid())
  user                            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                          String
  createdAt                       DateTime       @default(now())
  updatedAt                       DateTime       @updatedAt

  userDescriptionEncrypted        String         // e.g. "the 10-year-old with two braids" (encrypted)
  channel                         String?        // visual | kinesthetic | emotional | cognitive | verbal
  safeDistanceEncrypted           String?        // "across the room" | "right beside me" (encrypted)
  compassionBridgeQuality         String?        // compassion | curiosity | acceptance | willingness_to_comfort
  currentRestingPlaceEncrypted    String?        // "with the Adult Self" | "the inner garden" (encrypted)
  active                          Boolean        @default(true)

  @@index([userId])
}

// =============================================================================
// JOURNEY FOREIGN FILES — material identified as not-mine, released or pending
// =============================================================================
model JourneyForeignFile {
  id                              String         @id @default(cuid())
  user                            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                          String
  createdAt                       DateTime       @default(now())
  identifiedAt                    DateTime?
  // Journey P1 (2026-07-19) — release-semantics split (audit A8/B6).
  // releaseClaimedAt = the AI reported a symbolic release (PROVISIONAL claim).
  // releasedAt       = release CONFIRMED by the user across time (relief that
  //                    held, stable next check-in). Only releasedAt counts
  //                    toward the Stage 5 gate. releaseInvalidated clears both,
  //                    reopening the work. Historical rows with releasedAt set
  //                    are grandfathered as confirmed (recorded under the old
  //                    semantics; retro-demoting would erase real progress).
  releaseClaimedAt                DateTime?
  releasedAt                      DateTime?

  userDescriptionEncrypted        String         // "I must always be useful" (encrypted)
  originDescriptionEncrypted      String?        // "my mother" | "unknown but not mine" (encrypted)
  returnedToEncrypted             String?        // "back to my mother's house" (encrypted)
  honouringPhraseEncrypted        String?        // "this was yours, I return it..." (encrypted)
  whatStaysAsMineEncrypted        String?        // "I love to make things for people" (encrypted)

  @@index([userId])
}

// =============================================================================
// JOURNEY SIGNATURE IMAGES — images the user discovered in their work
// =============================================================================
model JourneySignatureImage {
  id                              String         @id @default(cuid())
  user                            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                          String
  createdAt                       DateTime       @default(now())

  userDescriptionEncrypted        String         // "the field of bluebells" (encrypted)
  context                         String?        // brief operational tag (no user content)

  @@index([userId])
}

// =============================================================================
// JOURNEY PATTERNS — unresolved psychological patterns the AI has noticed
// =============================================================================
// Journey polish PR 5 (2026-07-04). Structural storage for the working
// notes the AI otherwise dumps into the free-text continuityNote blob:
// "fear_of_visibility", "mother_voice", "money_shame", "body_shame",
// "self_abandonment", "not_allowed_to_want", etc.
//
// Design decisions locked with owner 2026-07-04:
//   - `category` is a free-string snake_case identifier the LLM emits.
//     NOT an enum — "working notes, not diagnosis." Taxonomy emerges from
//     real usage; can be normalised later once a shape is visible.
//   - `userDescription` (encrypted) captures the user's own words about
//     the pattern — never the AI's paraphrase.
//   - `firstObservedAt` never changes after row creation.
//   - `lastConfirmedAt` bumps every turn the pattern surfaces in the
//     state report's patternsTouched. PR 6 uses this to flag staleness
//     ("this pattern hasn't shown up in N days — reconfirm?").
//   - `active` defaults true. Monotonic write-once-true for now (matches
//     JourneyPart semantics). PR 6 or later may add a "resolved" flow.
//   - `context` is optional JSON for structured extras — e.g.
//     `{ ageTag: 9 }` for inner-child variants. Kept generic so the
//     shape can grow without another migration.
model JourneyPattern {
  id                              String         @id @default(cuid())
  user                            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                          String
  createdAt                       DateTime       @default(now())
  updatedAt                       DateTime       @updatedAt

  category                        String         // snake_case, e.g. "fear_of_visibility"
  userDescriptionEncrypted        String         // user's exact words (encrypted)
  firstObservedAt                 DateTime       @default(now())
  lastConfirmedAt                 DateTime       @default(now())
  active                          Boolean        @default(true)
  context                         Json?          // optional structured extras — e.g. { ageTag: 9 }

  // One row per (user, category) — dedup on category, not description.
  // Description evolves as the user's words about the pattern deepen; the
  // category label stays stable.
  @@unique([userId, category])
  @@index([userId])
  @@index([userId, active, lastConfirmedAt])
}

// =============================================================================
// JOURNEY MESSAGES — the conversation surface, encrypted at rest
// =============================================================================
model JourneyMessage {
  id                   String         @id @default(cuid())
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
  createdAt            DateTime       @default(now())

  role                 String         // user | assistant
  contentEncrypted     String
  stageAtTime          Int

  @@index([userId, createdAt])
}

// =============================================================================
// PRACTICES — individual exercises completed within sessions
// =============================================================================
model Practice {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String

  conversationId  String?   // which session it was part of, if any
  practiceCode    String    // grounding_5_senses | breath_box | body_scan | parts_dialogue | ...

  durationSeconds Int?
  completedAt     DateTime  @default(now())
  userRating      Int?      // 1..5 helpfulness
  notes           String?

  @@index([userId, completedAt])
}

// =============================================================================
// AI USAGE — one row per Anthropic API call (streaming or non-streaming)
// =============================================================================
// Captures the token counts Anthropic returns in each response and derives a
// $ cost using a per-model pricing table (see lib/ai-usage/cost.ts). Written
// fire-and-forget from each call site so a DB blip never breaks a user turn.
//
// Why a separate table (not fields on JourneyTurn): we want visibility on
// MiniMind chat, both safety verifiers, the MiniMind memory updater, and
// support-ticket categorisation — all Anthropic call sites. Grouping them
// all here lets one admin query answer "what's this user costing me this
// month across every surface?" and "what's my total AI spend today?".
//
// userId is nullable because a few call sites (support_categorise) have no
// user context. journeyTurnId is a nullable FK back to the audit row so a
// reviewer looking at one Journey turn can see its exact Anthropic cost.
model AiUsage {
  id                     String       @id @default(cuid())
  createdAt              DateTime     @default(now())

  user                   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId                 String?

  // Which code path spent this. See CALL_SITES in lib/ai-usage/record.ts.
  //   journey_turn         — main Journey streaming call
  //   minimind_chat        — main MiniMind streaming call
  //   verifier_journey     — Journey safety verifier (Haiku)
  //   verifier_minimind    — MiniMind safety verifier (Haiku)
  //   memory_updater       — MiniMind memory updater
  //   support_categorise   — support-ticket categorisation
  callSite               String

  // Anthropic model ID as returned in the response (or requested if not
  // present in the response — some models omit .model on stream events).
  model                  String

  // Token counts as reported by Anthropic in `response.usage` /
  // `finalMessage.usage`. cache_read + cache_creation split lets us see the
  // caching health per turn (high cache_read = cache warm; high cache_write
  // + no reads = cold or invalidated).
  inputTokens            Int
  outputTokens           Int
  cacheReadTokens        Int          @default(0)
  cacheCreationTokens    Int          @default(0)

  // $ USD, computed at write time from the model's pricing (see
  // lib/ai-usage/cost.ts). Stored so aggregate queries don't have to
  // re-multiply and can survive pricing changes without back-recompute.
  costUsd                Float

  // Optional FK back to the Journey audit row this call produced. Written
  // by the Journey turn hook; null for MiniMind + support paths.
  journeyTurnId          String?

  // Composite indexes for the common admin queries: per-user monthly spend,
  // per-day totals, per-call-site totals.
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([callSite, createdAt])
}

// =============================================================================
// STATES & THEMES — state modules (short single-topic reset conversations)
// =============================================================================
// Each state module (anxiety, apathy, loss_of_self, inner_emptiness) is
// bought via Stripe as a Purchase(productType='state_module', productId=<slug>)
// with a 30-day accessExpiresAt window. During that window the user can
// start any number of fresh sessions in the module. Each session runs to
// completion (CheckStabilization returns true) or red-flag closure,
// then archives. The next visit starts a fresh session.
//
// Not tied to Journey infrastructure — separate DB tables so state
// analytics stay clean and Journey code paths untouched.

model StateSession {
  id                String    @id @default(cuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  // Slug of the module: 'anxiety' | 'apathy' | 'loss_of_self' | 'inner_emptiness'
  // Kept as string (not enum) so adding a new state is a code-only change,
  // no migration required.
  moduleId          String

  startedAt         DateTime  @default(now())
  // Set when CheckStabilization detects completion OR red-flag triggers.
  completedAt       DateTime?
  // 'stabilised' — normal happy completion
  // 'red_flag' — safety trigger; user routed to crisis resources
  // 'abandoned' — user left mid-session (heuristic: no message in >2h)
  completionReason  String?

  // Denormalised for the module-catalogue "N sessions completed" counter
  // and for the AI's turn context (session message count).
  turnCount         Int       @default(0)

  messages          StateMessage[]

  @@index([userId, moduleId, startedAt])
  @@index([userId, moduleId, completedAt])
}

model StateMessage {
  id               String    @id @default(cuid())
  session          StateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId        String

  role             String    // 'user' | 'assistant'
  // User's message OR assistant reply, both encrypted at rest (same
  // pattern as JourneyMessage.contentEncrypted).
  contentEncrypted String    @db.Text

  createdAt        DateTime  @default(now())

  @@index([sessionId, createdAt])
}

// PR ψ5 (2026-07-14). Cross-session memory for state modules.
// StateSession is one-shot: each visit starts fresh, completes, archives.
// StateModuleMemory carries a running summary of "what worked / what
// keeps coming up" ACROSS sessions within the 30-day access window so
// session #3 knows session #1's 4-7-8 breath landed. Regenerated via
// a Haiku call in the turn API's waitUntil block on SESSION_COMPLETE
// (skipping red_flag closes). Same enc:v1 format as StateMessage.
model StateModuleMemory {
  id                     String    @id @default(cuid())
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String

  moduleId               String    // 'anxiety' | 'apathy' | 'loss_of_self' | 'inner_emptiness'

  memorySummaryEncrypted String    @db.Text
  memorySummaryUpdatedAt DateTime
  // Aggregate turn count across all sessions on this module at the
  // moment the summary was last generated. Used only as a lightweight
  // "when was this last refreshed?" indicator for admin / debug.
  memorySummaryTurnCount Int       @default(0)

  createdAt              DateTime  @default(now())

  @@unique([userId, moduleId])
  @@index([userId])
}

// =============================================================================
// THEMES — deep thematic modules
// =============================================================================
// PR χ1 (2026-07-13). Multi-session: unlike StateSession (fresh conversation
// per visit), Theme work is a continuing arc within the 30-day access window.
// One ThemeSession per (userId, moduleId) — the reader picks up where they
// left off across visits. If the user re-buys after expiry, the same session
// resumes (their prior work is not thrown away).
//
// The three-level structure (surface / middle / deep-refer) is prompt-driven,
// not encoded in the schema — the AI decides adaptively per Julia's decision
// (2026-07-13).
model ThemeSession {
  id                String    @id @default(cuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  // Slug of the theme: 'shame' | 'money' | 'body' | 'family' | 'self_realisation'
  // Kept as string (not enum) so adding a new theme is a code-only change.
  moduleId          String

  startedAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())
  // Set when the AI's SESSION_COMPLETE marker fires OR safety triggers.
  // Themes can be re-opened after "completion" — the marker is more like
  // "you've reached a natural checkpoint" than a hard terminal state.
  completedAt       DateTime?
  completionReason  String?

  turnCount         Int       @default(0)

  // Rolling memory summary of the whole arc so far. Regenerated via a
  // lightweight Haiku call every ~15 turns; loaded into the system
  // prompt on every subsequent turn so the AI has continuity even when
  // the recent-N message window has moved past the older material.
  // Same encryption format as ThemeMessage.contentEncrypted.
  memorySummaryEncrypted   String?   @db.Text
  memorySummaryUpdatedAt   DateTime?
  memorySummaryTurnCount   Int       @default(0)

  messages          ThemeMessage[]

  // One active row per user+theme. If the user re-opens the theme after a
  // gap, the same row is loaded (multi-session continuity).
  @@unique([userId, moduleId])
  @@index([userId, lastActiveAt])
}

model ThemeMessage {
  id               String    @id @default(cuid())
  session          ThemeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId        String

  role             String    // 'user' | 'assistant'
  // Encrypted at rest, same enc:v1: format as JourneyMessage / StateMessage.
  contentEncrypted String    @db.Text

  createdAt        DateTime  @default(now())

  @@index([sessionId, createdAt])
}
